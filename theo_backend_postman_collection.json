        {
          "name": "Reset Password",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"test@example.com\",\n  \"newPassword\": \"NewPassword@123\",\n  \"confirmPassword\": \"NewPassword@123\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/auth/reset-password",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "auth",
                "reset-password"
              ]
            }
          }
        },
        {
          "name": "Delete Account",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{token}}",
                  "type": "string"
                }
              ]
            },
            "method": "DELETE",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"password\": \"Password@123\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/auth/delete-me",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "auth",
                "delete-me"
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Accommodation (Host)",
      "item": [
        {
          "name": "Create Accommodation",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{token}}",
                  "type": "string"
                }
              ]
            },
            "method": "POST",
            "header": [],
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "name", "value": "Appartement T3 – City Center", "type": "text" },
                { "key": "accommodationType", "value": "Apartment", "type": "text" },
                { "key": "address", "value": "15 Rue de la Paix, 75002 Paris", "type": "text" },
                { "key": "city", "value": "Paris", "type": "text" },
                { "key": "zipCode", "value": "75002", "type": "text" },
                { "key": "floor", "value": "3rd Floor", "type": "text" },
                { "key": "doorCode", "value": "1234", "type": "text" },
                { "key": "numberOfRooms", "value": "3", "type": "text" },
                { "key": "surface", "value": "65", "type": "text" },
                { "key": "hasElevator", "value": "true", "type": "text" },
                { "key": "cleaningRate", "value": "55", "type": "text" },
                { "key": "notes", "value": "A bright, quiet apartment.", "type": "text" },
                { "key": "keys", "value": "Key box at the entrance", "type": "text" },
                { "key": "accessCode", "value": "A1B2C3", "type": "text" },
                { "key": "instructions", "value": "Please close the windows after cleaning.", "type": "text" },
                { "key": "frequency", "value": "Every week", "type": "text" },
                { "key": "photos", "type": "file", "src": "" }
              ]
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/accommodation",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "accommodation"]
            }
          }
        },
        {
          "name": "Get My Accommodations (filter + pagination)",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{token}}",
                  "type": "string"
                }
              ]
            },
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/v1/accommodation?page=1&limit=10&status=&search=&city=&accommodationType=",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "accommodation"],
              "query": [
                { "key": "page", "value": "1" },
                { "key": "limit", "value": "10" },
                { "key": "status", "value": "", "description": "scheduled | not_scheduled" },
                { "key": "search", "value": "", "description": "Search by name" },
                { "key": "city", "value": "", "description": "Filter by city" },
                { "key": "accommodationType", "value": "", "description": "Apartment, House, Studio..." }
              ]
            }
          }
        },
        {
          "name": "Get Accommodation By ID",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{token}}",
                  "type": "string"
                }
              ]
            },
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/v1/accommodation/:id",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "accommodation", ":id"],
              "variable": [
                { "key": "id", "value": "ACCOMMODATION_ID_HERE" }
              ]
            }
          }
        },
        {
          "name": "Update Accommodation",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{token}}",
                  "type": "string"
                }
              ]
            },
            "method": "PATCH",
            "header": [],
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "name", "value": "Updated Name", "type": "text" },
                { "key": "cleaningRate", "value": "70", "type": "text" },
                { "key": "status", "value": "scheduled", "type": "text" },
                { "key": "photos", "type": "file", "src": "" }
              ]
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/accommodation/:id",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "accommodation", ":id"],
              "variable": [
                { "key": "id", "value": "ACCOMMODATION_ID_HERE" }
              ]
            }
          }
        },
        {
          "name": "Delete Accommodation",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{token}}",
                  "type": "string"
                }
              ]
            },
            "method": "DELETE",
            "url": {
              "raw": "{{baseUrl}}/api/v1/accommodation/:id",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "accommodation", ":id"],
              "variable": [
                { "key": "id", "value": "ACCOMMODATION_ID_HERE" }
              ]
            }
          }
        }
      ]
    }
  ],
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:5000"
    },
    {
      "key": "token",
      "value": "your_jwt_token_here"
    }
  ]
}